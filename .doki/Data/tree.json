{
  "$schema": "XBridge v1.1 — Tree",
  "description": "Architekturstruktur und Abhängigkeitsgraph. Jede Datei im Projekt MUSS hier mit ihren Abhängigkeiten registriert sein. Dient als Bauplan für LLM-Agenten und als Single Source of Truth für die Systemarchitektur.",
  "version": "0.1.0-seed",
  "status": "seed — v1.1 DocSync-Enforcement pending",
  "last_updated": "2026-06-26",
  "updated_by": "Buffy (Genesis)",

  "architecture": {
    "pattern": "Layered Monolith → Microservices (geplant)",
    "current_phase": "Phase 1: Commit-Layer (Foundation)",
    "namespace_root": "XBridge",
    "dependency_rule": "Inward-only: Core ← Persistence ← Providers ← Adapters ← CLI/GUI"
  },

  "layers": [
    {
      "name": "XBridge.CommitLayer",
      "layer_index": 1,
      "type": "Foundation",
      "description": "Commit-Narrative Engine — kein externer Dependency außer System/System.Text.Json",
      "status": "active",
      "version": "0.1.0",
      "dependencies": {
        "external": [],
        "internal": [],
        "system": ["System", "System.IO", "System.Linq", "System.Text.Json", "System.Text.RegularExpressions", "System.Diagnostics", "System.Collections.Generic"]
      },

      "files": [
        {
          "path": "XBridge.CommitLayer/RngEngine.cs",
          "type": "static class",
          "layer": "Core Math",
          "dependencies": [],
          "dependents": ["CompositeEngine.cs", "CommitOrchestrator.cs", "SidePlotEngine.cs", "VoiceComposer.cs"],
          "description": "Fundament: XorShift128 + Djb2 + Composite-Derivation. KEINE Abhängigkeiten."
        },
        {
          "path": "XBridge.CommitLayer/CompositeEngine.cs",
          "type": "class",
          "layer": "Chain Layer",
          "dependencies": ["RngEngine.cs"],
          "dependents": ["CommitOrchestrator.cs", "NarratorEngine.cs", "ArcEngine.cs", "SidePlotEngine.cs"],
          "description": "Chain-Management, Mood-Non-Repeat, Cross-Narrator"
        },
        {
          "path": "XBridge.CommitLayer/NarratorEngine.cs",
          "type": "class",
          "layer": "Character Layer",
          "dependencies": ["Data/character_sheets.json", "Data/narrative_params.json"],
          "dependents": ["CommitOrchestrator.cs", "VoiceComposer.cs"],
          "description": "Lädt 14 Charaktere, wendet Mood-Deltas an"
        },
        {
          "path": "XBridge.CommitLayer/VoiceComposer.cs",
          "type": "class",
          "layer": "Prompt Layer",
          "dependencies": ["NarratorEngine.cs", "RngEngine.cs", "RelationshipEngine.cs"],
          "dependents": ["CommitOrchestrator.cs"],
          "description": "Baut LLM-Prompt mit Charakter+Sentiment+Arc+SidePlot+Trivial"
        },
        {
          "path": "XBridge.CommitLayer/RelationshipEngine.cs",
          "type": "class",
          "layer": "Sentiment Layer",
          "dependencies": ["CompositeEngine.cs"],
          "dependents": ["VoiceComposer.cs"],
          "description": "Berechnet dynamisches Sentiment (0-10) aus Chain-Historie"
        },
        {
          "path": "XBridge.CommitLayer/ChangeIndexEngine.cs",
          "type": "class",
          "layer": "Documentation Layer",
          "dependencies": ["RngEngine.cs"],
          "dependents": ["CommitOrchestrator.cs"],
          "description": "git diff → Entitäten mit Zeilennummern + F-xxx IDs"
        },
        {
          "path": "XBridge.CommitLayer/VerifyEngine.cs",
          "type": "class",
          "layer": "Validation Layer",
          "dependencies": ["Data/character_sheets.json", "CompositeEngine.cs", "ChangeIndexEngine.cs"],
          "dependents": ["CommitOrchestrator.cs"],
          "description": "9 Checks: Token, Impulse, Storytelling, Narrator, Composite, CrossNarrator, Kausalität, DocSync, ChainAudit"
        },
        {
          "path": "XBridge.CommitLayer/CommitOrchestrator.cs",
          "type": "class",
          "layer": "Orchestration Layer",
          "dependencies": ["RngEngine.cs", "CompositeEngine.cs", "NarratorEngine.cs", "VoiceComposer.cs", "RelationshipEngine.cs", "ChangeIndexEngine.cs", "VerifyEngine.cs", "ArcEngine.cs", "SidePlotEngine.cs"],
          "dependents": [],
          "description": "Zentraler Orchestrator: Commit() + GitHelper (treeHash, diffHash, Merge-Erkennung)"
        },
        {
          "path": "XBridge.CommitLayer/ArcEngine.cs",
          "type": "class",
          "layer": "Narrative Layer",
          "dependencies": ["CompositeEngine.cs", "Data/lore_arcs.json"],
          "dependents": ["CommitOrchestrator.cs"],
          "description": "Emergente Handlungsbögen: Gewichtsformel, ARC_CLIMAX-Trigger"
        },
        {
          "path": "XBridge.CommitLayer/SidePlotEngine.cs",
          "type": "class",
          "layer": "Narrative Layer",
          "dependencies": ["RngEngine.cs", "CompositeEngine.cs"],
          "dependents": ["CommitOrchestrator.cs", "VoiceComposer.cs"],
          "description": "Branch/Merge-Logik: MERGE_HEAD-Erkennung, Divergenz, SidePlot-Kontext"
        }
      ],

      "data_files": [
        {
          "path": "XBridge.CommitLayer/Data/character_sheets.json",
          "type": "Seed Data",
          "dependencies": [],
          "dependents": ["NarratorEngine.cs", "VerifyEngine.cs"],
          "description": "14 Charaktere mit VoiceTraits, Attitudes, Relationships"
        },
        {
          "path": "XBridge.CommitLayer/Data/narrative_params.json",
          "type": "Seed Data",
          "dependencies": [],
          "dependents": ["NarratorEngine.cs"],
          "description": "Mood-Deltas, Narrator-Mood-Kombinationen, Decoding-Tables"
        },
        {
          "path": "XBridge.CommitLayer/Data/lore_arcs.json",
          "type": "Seed Data",
          "dependencies": [],
          "dependents": ["ArcEngine.cs", "CommitOrchestrator.cs"],
          "description": "Arc-Registry: aktiver Arc + archivierte Arcs"
        },
        {
          "path": "XBridge.CommitLayer/Data/narrative_chain.json",
          "type": "Runtime State",
          "dependencies": [],
          "dependents": ["CompositeEngine.cs"],
          "description": "Chain-State: genesis_composite + genesis_mood + entries[]"
        },
        {
          "path": "XBridge.CommitLayer/Data/writing_rules.json",
          "type": "Documentation",
          "dependencies": [],
          "dependents": [],
          "description": "Schreibregeln-Doku (in VerifyEngine.cs hartkodiert)"
        },
        {
          "path": "XBridge.CommitLayer/Data/string_matrix.json",
          "type": "Seed Data",
          "dependencies": [],
          "dependents": [],
          "description": "String-Key-Registry — v1.1 DocSync",
          "status": "seed"
        },
        {
          "path": "XBridge.CommitLayer/Data/inventory.json",
          "type": "Documentation",
          "dependencies": [],
          "dependents": [],
          "description": "Asset-/Komponenten-Register — v1.1 DocSync",
          "status": "seed"
        },
        {
          "path": "XBridge.CommitLayer/Data/tree.json",
          "type": "Documentation",
          "dependencies": [],
          "dependents": [],
          "description": "Architekturstruktur — v1.1 DocSync",
          "status": "seed"
        },
        {
          "path": "XBridge.CommitLayer/Data/change_index.json",
          "type": "Runtime Generated",
          "dependencies": [],
          "dependents": ["ChangeIndexEngine.cs", "VerifyEngine.cs"],
          "description": "Auto-generiertes Entitäten-Register"
        }
      ],

      "runtime_files": [
        {
          "path": "CHANGELOG.md",
          "type": "Runtime Generated",
          "dependencies": [],
          "dependents": ["VerifyEngine.cs"],
          "description": "Auto-generierte Commit-Chronik"
        }
      ]
    }
  ],

  "planned_layers": [
    {
      "name": "XBridge.Core",
      "layer_index": 2,
      "type": "Business Logic",
      "dependencies": ["XBridge.CommitLayer"],
      "status": "planned",
      "description": "Übersetzungs-Pipeline, Domain-Modelle"
    },
    {
      "name": "XBridge.Persistence",
      "layer_index": 3,
      "type": "Data Access",
      "dependencies": ["XBridge.Core"],
      "status": "planned",
      "description": "DB-Zugriffe, Repository-Pattern"
    },
    {
      "name": "XBridge.Providers",
      "layer_index": 4,
      "type": "Infrastructure",
      "dependencies": ["XBridge.Core"],
      "status": "planned",
      "description": "Externe API-Clients, Service-Integrationen"
    },
    {
      "name": "XBridge.Adapters",
      "layer_index": 5,
      "type": "Application",
      "dependencies": ["XBridge.Core", "XBridge.Persistence", "XBridge.Providers"],
      "status": "planned",
      "description": "Spiel-spezifische Adapter (kein if (game == ...))"
    },
    {
      "name": "XBridge.Cli",
      "layer_index": 6,
      "type": "Presentation",
      "dependencies": ["XBridge.Adapters"],
      "status": "planned",
      "description": "CLI-Interface (Codebuff-Integration)"
    },
    {
      "name": "XBridge.GUI",
      "layer_index": 7,
      "type": "Presentation",
      "dependencies": ["XBridge.Adapters"],
      "status": "planned",
      "description": "ASP.NET Core Web-Frontend"
    }
  ],

  "dependency_graph_summary": {
    "description": "Vereinfachter Abhängigkeitsgraph (→ = depends on)",
    "graph": [
      "CommitOrchestrator → ALL engines",
      "VoiceComposer → NarratorEngine, RelationshipEngine, RngEngine",
      "ArcEngine → CompositeEngine, lore_arcs.json",
      "SidePlotEngine → RngEngine, CompositeEngine",
      "ChangeIndexEngine → RngEngine",
      "VerifyEngine → character_sheets.json, ChangeIndexEngine, CompositeEngine",
      "NarratorEngine → character_sheets.json, narrative_params.json",
      "RelationshipEngine → CompositeEngine",
      "CompositeEngine → RngEngine",
      "RngEngine → (nothing — leaf dependency)"
    ]
  },

  "sync_rules": {
    "description": "Regeln für Tree ↔ Dateisystem Synchronisation",
    "check_on_commit": "v1.1 — VerifyEngine Check 12 prüft: alle .cs/.json auf Disk sind im Tree",
    "check_on_build": "Build-Warning wenn Datei auf Disk aber nicht im Tree",
    "stale_detection": "Tree-Einträge ohne Disk-Datei → Error (Tree lügt)",
    "circular_dependency_check": "Build-Error wenn zirkuläre Abhängigkeiten erkannt"
  }
}
